@use "variables";

$sidebar-gradient-start: #ffe08a;
$radius: 20px;
$radius-sm: 12px;
$shadow-card: 0 12px 40px rgba(0, 0, 0, 0.1);
$shadow-sidebar: 0 10px 30px rgba(variables.$secondary-color, 0.18);
$shadow-avatar: 0 6px 18px rgba(0, 0, 0, 0.12);
$text-color: #1F252B;
$border-light: #eee;
$day-disabled: #d0d0d0;
$day-other-month: #c4c4c4;
$container: 1180px;

.container {
  width: 100%;
  max-width: $container;
  margin: 0 auto;
  padding: 0 1.25rem;
}

// ===== HERO =====

.hero {
  background: variables.$page-bg;
  color: variables.$text-dark;
  padding: 2rem 0 5.5rem;
  position: relative;
  overflow: hidden;

  &::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 48px;
    background: variables.$page-bg;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }
}

.hero__inner {
  display: grid;
  gap: 2rem;
  align-items: center;
}

.hero__titulo {
  font-size: clamp(1.65rem, 4vw, 2.35rem);
  font-weight: 900;
  margin-bottom: 0.75rem;
  position: relative;
}

.hero__texto {
  opacity: 0.92;
  font-weight: 600;
}

@media (min-width: 768px) {
  .hero__inner {
    grid-template-columns: 1fr auto;
  }
}

// ===== PASOS =====

.pasos {
  display: flex;
  justify-content: center;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .pasos {
    justify-content: flex-end;
  }
}

.hero .paso {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.45rem;
  min-width: 72px;
  position: relative;

  &:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 17px;
    left: calc(50% + 18px);
    width: calc(100% - 36px);
    height: 2px;
    background: rgba(variables.$text-dark, 0.2);
  }

  small {
    font-size: 0.78rem;
    font-weight: 700;
    color: rgba(variables.$text-dark, 0.7);
  }
}

.hero .paso__circulo {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  font-size: 0.85rem;
  font-weight: 800;
  background: rgba(variables.$text-dark, 0.1);
  border: 2px solid rgba(variables.$text-dark, 0.25);
  color: variables.$text-dark;
}

.hero .paso::before {
  display: none;
}

.hero .paso--hecho .paso__circulo,
.hero .paso--activo .paso__circulo {
  background: variables.$accent-color;
  border-color: variables.$accent-color;
  color: variables.$white;
}

// ===== MAIN LAYOUT =====

.main {
  flex: 1;
  margin-top: -3rem;
  padding-bottom: 3rem;
  position: relative;
  z-index: 5;
}

.main__grid {
  display: grid;
  gap: 1.5rem;
}

@media (min-width: 960px) {
  .main__grid {
    grid-template-columns: 1fr 300px;
    gap: 1.75rem;
  }
}

// ===== BUTTONS (scoped to avoid conflict with main .btn) =====

.calendario-page .btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.85rem 1.4rem;
  border-radius: 999px;
  font-size: 0.95rem;
  font-weight: 800;
  border: 2px solid variables.$accent-color;
  min-width: 0;
  height: auto;
  text-decoration: none;
  transition: background 0.2s, color 0.2s, opacity 0.2s;

  &:hover:not(:disabled) {
    filter: brightness(1.05);
  }

  &:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
}

.calendario-page .btn--primario {
  background: variables.$accent-color;
  color: variables.$white;
  border-color: variables.$accent-color;
}

.calendario-page .btn--secundario {
  background: variables.$white;
  color: variables.$accent-color;

  &:hover {
    background: rgba(variables.$accent-color, 0.08);
  }
}

.calendario-page .btn--circulo {
  width: 34px;
  height: 34px;
  padding: 0;
  border-radius: 50%;
  background: variables.$white;
  color: variables.$accent-color;

  &:hover:not(:disabled) {
    background: variables.$accent-color;
    color: variables.$white;
  }

  &:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
}

// ===== AGENDA =====

.agenda {
  background: variables.$formbg;
  border-radius: $radius;
  padding: clamp(1.35rem, 3vw, 2rem);
  box-shadow: $shadow-card;
}

.agenda__titulo {
  font-size: clamp(1.35rem, 2.5vw, 1.65rem);
  font-weight: 900;
  margin-bottom: 1.25rem;
}

// Resumen
.resumen {
  display: grid;
  gap: 0.85rem;
  padding: 1rem 1.15rem;
  background: variables.$cardbg;
  border-radius: $radius-sm;
  margin-bottom: 1.75rem;
}

@media (min-width: 600px) {
  .resumen {
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
}

.resumen__item {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  min-width: 0;
}

.resumen__icono {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: variables.$white;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.resumen-paw {
  width: 20px;
  height: auto;
}

.resumen-icon-img {
  width: 22px;
  height: auto;
}

.resumen__label {
  display: block;
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: variables.$muted-color;
}

.resumen__valor {
  display: block;
  font-size: 0.92rem;
  font-weight: 800;
}

// Grid calendario + horarios
.agenda__grid {
  display: grid;
  gap: 2rem;
}

@media (min-width: 700px) {
  .agenda__grid {
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }
}

.bloque__titulo {
  font-size: 1rem;
  font-weight: 900;
  margin-bottom: 1rem;
}

// Calendario
.calendario {
  border: 1px solid #e8e8e8;
  border-radius: $radius-sm;
  padding: 1rem;
  background: variables.$white;
}

.calendario__cabecera {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.calendario__mes {
  font-size: 1.05rem;
  font-weight: 900;
}

.calendario__nav {
  display: flex;
  gap: 0.35rem;
}

.calendario__dias-semana,
.calendario__dias {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0.25rem;
}

.calendario__dias-semana {
  margin-bottom: 0.5rem;
  text-align: center;
  font-size: 0.78rem;
  font-weight: 800;
  color: variables.$muted-color;
}

.dia-btn {
  aspect-ratio: 1;
  border: none;
  background: transparent;
  border-radius: 50%;
  font-size: 0.92rem;
  font-weight: 700;
  color: $text-color;
  position: relative;
  display: grid;
  place-items: center;

  &:hover:not(:disabled):not(.seleccionado) {
    background: rgba(variables.$accent-color, 0.12);
  }

  &:disabled {
    color: $day-disabled;
    cursor: not-allowed;
  }

  &.otro-mes {
    color: $day-other-month;
  }

  &.disponible::after {
    content: "";
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: variables.$accent-color;
  }

  &.seleccionado {
    background: variables.$secondary-color;
    color: variables.$white;

    &.disponible::after {
      background: variables.$white;
    }
  }
}

// Horarios
.horarios {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.65rem;
}

.horario-btn {
  padding: 0.75rem 0.5rem;
  border: 2px solid variables.$accent-color;
  border-radius: $radius-sm;
  background: variables.$white;
  color: variables.$accent-color;
  font-size: 0.95rem;
  font-weight: 800;

  &:hover {
    background: rgba(variables.$accent-color, 0.08);
  }

  &.seleccionado {
    background: variables.$accent-color;
    color: variables.$white;
  }
}

.horarios__mensaje {
  grid-column: 1 / -1;
  padding: 1.5rem 1rem;
  text-align: center;
  color: variables.$muted-color;
  font-size: 0.92rem;
  background: variables.$cardbg;
  border-radius: $radius-sm;
}

// Acciones
.agenda__acciones {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: space-between;
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid $border-light;
}

@media (max-width: 599px) {
  .agenda__acciones {
    flex-direction: column;
  }

  .agenda__acciones .btn {
    width: 100%;
  }
}

// ===== SIDEBAR =====

.sidebar {
  background: linear-gradient(160deg, $sidebar-gradient-start 0%, variables.$highlight-color 100%);
  border-radius: $radius;
  padding: 1.5rem 1.35rem;
  box-shadow: $shadow-sidebar;
}

.sidebar__titulo {
  font-size: 1.15rem;
  font-weight: 900;
  margin-bottom: 1rem;
}

.sidebar__foto {
  width: 132px;
  height: 132px;
  border-radius: 50%;
  border: 5px solid variables.$white;
  background: variables.$white;
  margin: 0 auto 1.1rem;
  display: grid;
  place-items: center;
  font-size: 2.5rem;
  box-shadow: $shadow-avatar;
}

.sidebar__lista {
  display: grid;
  gap: 0.65rem;
  margin-bottom: 1.1rem;

  li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.35;
  }
}

.sidebar__check {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: variables.$accent-color;
  color: variables.$white;
  display: grid;
  place-items: center;
  font-size: 0.72rem;
  font-weight: 900;
  flex-shrink: 0;
}

.sidebar__horario {
  background: rgba(variables.$white, 0.72);
  border-radius: $radius-sm;
  padding: 0.85rem 1rem;

  strong {
    display: block;
    font-size: 0.82rem;
    margin-bottom: 0.2rem;
  }

  span {
    font-size: 0.88rem;
    font-weight: 700;
    color: variables.$muted-color;
  }
}
